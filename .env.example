# ============================================================
# PersonalLog Environment Configuration
# ============================================================
# Copy this file to .env.local for local development
# For production deployment, configure these in Vercel Dashboard
# https://vercel.com/dashboard
# ============================================================

# ------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------

# Environment: development, staging, or production
NODE_ENV=development

# Port for local development server (default: 3002)
PORT=3002

# Base URL for deployment (auto-detected in most cases)
# Required for PWA manifest and service worker
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Enable/disable PWA features (true/false)
NEXT_PUBLIC_ENABLE_PWA=true

# Enable/disable analytics (true/false)
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ------------------------------------------------------------
# Build Configuration
# ------------------------------------------------------------

# Set to 'false' to skip WASM build during deployment
# Useful for environments without Rust toolchain
BUILD_WASM=false

# ------------------------------------------------------------
# AI Provider API Keys (Optional)
# ------------------------------------------------------------
# Add your API keys to enable specific AI providers
# Keys are NOT required for the app to run - they can be added
# later in the Settings UI

# OpenAI (GPT-4, GPT-3.5)
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# Get your key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini)
# Get your key: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=...

# X.ai (Grok)
# Get your key: https://console.x.ai/
# XAI_API_KEY=...

# DeepSeek
# Get your key: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=...

# Kimi (Moonshot)
# Get your key: https://platform.moonshot.cn/
# KIMI_API_KEY=...

# Z.ai
# Get your key: https://open.bigmodel.cn/
# ZAI_API_KEY=...

# ------------------------------------------------------------
# Storage Configuration
# ------------------------------------------------------------

# Path to packages directory for dynamic module loading
# Can be relative or absolute path
PACKAGES_PATH=../packages

# IndexedDB database name (default: PersonalLogDB)
# NEXT_PUBLIC_DB_NAME=PersonalLogDB

# IndexedDB database version (default: 1)
# NEXT_PUBLIC_DB_VERSION=1

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------

# Enable experimental features (true/false)
NEXT_PUBLIC_EXPERIMENTAL_FEATURES=false

# Enable hardware detection and adaptive optimization (true/false)
NEXT_PUBLIC_HARDWARE_DETECTION=true

# Enable knowledge base vector search (true/false)
NEXT_PUBLIC_ENABLE_KNOWLEDGE=true

# Enable AI contact system (true/false)
NEXT_PUBLIC_ENABLE_AI_CONTACTS=true

# ------------------------------------------------------------
# Performance & Monitoring (Optional)
# ------------------------------------------------------------

# Sentry DSN for error tracking
# Get your DSN: https://sentry.io/
# NEXT_PUBLIC_SENTRY_DSN=https://...

# Vercel Analytics (auto-enabled on Vercel deployments)
# No configuration needed

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# PostHog Analytics
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# Deployment-Specific Variables
# ------------------------------------------------------------
# These are automatically set by Vercel - DO NOT set manually

# VERCEL_URL=your-app.vercel.app
# VERCEL_ENV=production
# VERCEL_GIT_COMMIT_SHA=...
# VERCEL_GIT_COMMIT_MESSAGE=...
# VERCEL_GIT_COMMIT_REF=main

# ------------------------------------------------------------
# Development Only
# ------------------------------------------------------------

# Enable debug mode for additional logging (true/false)
DEBUG=false

# Enable webpack bundle analysis (true/false)
ANALYZE=false
