# npm configuration for PersonalLog deployment
# This ensures consistent behavior across all environments

# Use exact versions in package-lock.json
save-exact=true

# Don't update package-lock.json during install (CI/CD)
package-lock=false

# Log level
loglevel=warn

# Fund messages (disabled for cleaner CI output)
fund=false

# Audit messages (disabled for cleaner CI output)
audit=false

# Engine strict mode (enforce Node version requirement)
engine-strict=true

# Ensure legacy peer deps are handled properly
legacy-peer-deps=false

# Use deterministic builds
install-strategy=hoisted
