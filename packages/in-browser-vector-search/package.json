{
  "name": "@superinstance/in-browser-vector-search",
  "version": "1.0.0",
  "description": "Privacy-first in-browser vector search with semantic similarity and checkpointing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "vector-search",
    "semantic-search",
    "embeddings",
    "similarity",
    "knowledge-base",
    "privacy-first",
    "local-storage",
    "indexeddb",
    "wasm",
    "in-browser"
  ],
  "author": "SuperInstance",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/In-Browser-Vector-Search.git"
  },
  "bugs": {
    "url": "https://github.com/SuperInstance/In-Browser-Vector-Search/issues"
  },
  "homepage": "https://github.com/SuperInstance/In-Browser-Vector-Search#readme",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
