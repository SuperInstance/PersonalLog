{
  "name": "@superinstance/agentswarm",
  "version": "0.1.0",
  "description": "Market-based multi-agent coordination system where agents bid on tasks, specialize autonomously, and self-organize",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./market": {
      "import": "./dist/market.js",
      "types": "./dist/market.d.ts"
    },
    "./agent": {
      "import": "./dist/agent.js",
      "types": "./dist/agent.d.ts"
    },
    "./orchestrator": {
      "import": "./dist/orchestrator.js",
      "types": "./dist/orchestrator.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "multi-agent",
    "market-based",
    "coordination",
    "auction",
    "swarm",
    "distributed",
    "task-execution",
    "economic-optimization",
    "agent-intelligence",
    "emergent-behavior"
  ],
  "author": "SuperInstance",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/AgentSwarm"
  },
  "bugs": {
    "url": "https://github.com/SuperInstance/AgentSwarm/issues"
  },
  "homepage": "https://github.com/SuperInstance/AgentSwarm#readme",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
