    "openai",
    "anthropic",
    "claude",
    "gpt",
    "ollama",
    "cohere",
    "api-optimization",
    "cost-reduction",
    "ai-costs",
    "llm-costs",
    "prompt-optimization",
    "cache-optimization",
    "smart-routing",
    "query-analysis",
    "token-estimation",
    "budget-tracking",
    "cost-monitoring",
    "real-time-analytics",
    "ai-efficiency",
    "developer-tools",
    "machine-learning",
    "ai-tools"
  ],
  "author": "SuperInstance",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
