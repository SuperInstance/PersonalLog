{
  "name": "@superinstance/mpc-orchestration-optimization",
  "version": "1.0.0",
  "description": "Model Predictive Control (MPC) orchestrator for multi-agent optimization with predictive planning and resource management",
  "type": "module",
  "main": "dist/index.js",
