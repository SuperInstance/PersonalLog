{
  "name": "@superinstance/thoughtchain",
  "version": "0.1.0",
  "description": "Parallel reasoning verification system that reduces LLM errors by 60-80% through multi-model cross-validation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./verifiers": {
      "import": "./dist/verifiers/index.js",
      "types": "./dist/verifiers/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "reasoning",
    "verification",
    "llm",
    "ai",
    "parallel",
    "ensemble",
    "confidence",
    "backtracking",
    "chain-of-thought",
    "webgpu",
    "multi-model"
  ],
  "author": "SuperInstance",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/ThoughtChain"
  },
  "bugs": {
    "url": "https://github.com/SuperInstance/ThoughtChain/issues"
  },
  "homepage": "https://github.com/SuperInstance/ThoughtChain#readme",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
