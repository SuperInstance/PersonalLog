{
  "name": "personallog",
  "version": "1.0.0",
  "description": "SuperInstance personal logging app for everyday use",
  "private": true,
  "license": "MIT",
  "author": "SuperInstance",
  "homepage": "https://github.com/SuperInstance/PersonalLog#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/PersonalLog.git"
  },
  "bugs": {
    "url": "https://github.com/SuperInstance/PersonalLog/issues"
  },
  "scripts": {
    "dev": "npm run build:wasm && next dev -p 3002",
    "build": "npm run build:wasm && next build",
    "build:wasm": "cd native/rust && wasm-pack build --target web --weak-refs --out-dir pkg",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:wasm": "cd native/rust && wasm-pack test --node",
    "clean:wasm": "rm -rf native/rust/pkg"
  },
  "dependencies": {
    "next": "15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.525.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.3.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "superinstance",
    "personal",
    "logging",
    "journal",
    "notes",
    "productivity",
    "nextjs"
  ]
}
